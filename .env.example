# Supabase Postgres connection string (Session pooler URL)
# Example: postgres://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# JWT signing secret (required in production, at least 32 characters)
AUTH_SECRET=
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_GITHUB_REPO_URL=

# Phase-2 execution runner
# SANDBOX_MODE: 'safe' to call containerized runner, otherwise heuristic evaluator
SANDBOX_MODE=heuristic
SANDBOX_RUNNER_URL=http://localhost:8088
SANDBOX_RUNNER_TOKEN=

# Async submission job controls
SUBMISSION_TIMEOUT_MS=15000
SUBMISSION_MEMORY_LIMIT_MB=256

# Optional AI-assisted submission review
AI_REVIEW_ENABLED=false
AI_REVIEW_ENFORCE=false
AI_REVIEW_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Performance flags (useful in local dev after DB is already initialized)
# Ignored in production.
DB_AUTO_INIT_SCHEMA=true
DB_SKIP_SEED_CHECK=false

# Production hardening: keep false unless you intentionally allow runtime schema init in prod
PROD_DB_AUTO_INIT_SCHEMA=false

# Distributed rate limiting (recommended for production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
